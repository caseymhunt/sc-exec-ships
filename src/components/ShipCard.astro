---
interface Variant {
  label: string;
  erkulUrl: string;
}

interface Props {
  name: string;
  manufacturer: string;
  image: string;
  variants: Variant[];
}

const { name, manufacturer, image, variants } = Astro.props;

const imageIssueTitle = encodeURIComponent(`Image Submission: ${name}`);
const imageIssueBody = encodeURIComponent(
`## Image Submission

**Ship:** ${name}

**Image URL or attached file:**
<!-- Paste a direct image link, or attach a file by dragging it here -->

**Notes:**
<!-- Anything to flag about the image — source, quality, variant shown, etc. -->
`);
const imageIssueUrl = `https://github.com/caseymhunt/sc-exec-ships/issues/new?title=${imageIssueTitle}&body=${imageIssueBody}&labels=image`;

function loadoutIssueUrl(variantLabel: string) {
  const title = encodeURIComponent(`Loadout Submission: ${name} — ${variantLabel}`);
  const body = encodeURIComponent(
`## Loadout Submission

**Ship:** ${name}
**Variant:** ${variantLabel}

**Erkul.games loadout URL:**
<!-- Paste the full URL from erkul.games/loadout/... -->

**Notes:**
<!-- Anything else to flag — patch version, component changes, etc. -->
`);
  return `https://github.com/caseymhunt/sc-exec-ships/issues/new?title=${title}&body=${body}&labels=loadout`;
}
---

<article class="ship-card">
  <div class="image-wrap">
    <img src={image} alt={name} class="ship-image" />
    <div class="image-overlay"></div>
    <span class="manufacturer-badge">{manufacturer}</span>
    <a href={imageIssueUrl} target="_blank" rel="noopener noreferrer" class="img-cta" title="Submit an image">
      ⬆
    </a>
  </div>

  <div class="ship-body">
    <h2 class="ship-name">{name}</h2>

    <div class="variants">
      {variants.map((variant) => (
        variant.erkulUrl ? (
          <a href={variant.erkulUrl} target="_blank" rel="noopener noreferrer" class="variant-link">
            <span class="variant-label">{variant.label}</span>
            <span class="variant-action">VIEW LOADOUT ↗</span>
          </a>
        ) : (
          <a href={loadoutIssueUrl(variant.label)} target="_blank" rel="noopener noreferrer" class="variant-link loadout-cta">
            <span class="variant-label">{variant.label}</span>
            <span class="variant-action">SUBMIT LOADOUT ↗</span>
          </a>
        )
      ))}
    </div>
  </div>
</article>

<style>
  .ship-card {
    background: #0d1520;
    border: 1px solid #1a2e40;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    will-change: transform;
  }

  .ship-card::before {
    content: '';
    position: absolute;
    top: -1px;
    right: -1px;
    width: 14px;
    height: 14px;
    border-top: 2px solid #35b6ec;
    border-right: 2px solid #35b6ec;
    z-index: 2;
    pointer-events: none;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .ship-card::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: -1px;
    width: 14px;
    height: 14px;
    border-bottom: 2px solid #35b6ec;
    border-left: 2px solid #35b6ec;
    z-index: 2;
    pointer-events: none;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .ship-card:hover {
    border-color: #35b6ec;
    box-shadow: 0 0 20px rgba(53, 182, 236, 0.12), inset 0 0 20px rgba(53, 182, 236, 0.04);
  }

  .ship-card:hover::before,
  .ship-card:hover::after {
    opacity: 1;
  }

  /* ── Image ── */
  .image-wrap {
    position: relative;
    overflow: hidden;
  }

  .ship-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease, filter 0.4s ease;
    filter: saturate(0.85) brightness(0.9);
    will-change: transform;
    transform: translateZ(0);
  }

  .ship-card:hover .ship-image {
    transform: translateZ(0) scale(1.03);
    filter: saturate(1) brightness(1);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, #0d1520 100%);
    pointer-events: none;
  }

  .manufacturer-badge {
    position: absolute;
    bottom: 0.6rem;
    left: 0.75rem;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #35b6ec;
    opacity: 0.75;
  }

  /* Image CTA — icon button top-right, hover-reveal */
  .img-cta {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #35b6ec;
    font-size: 0.75rem;
    background: rgba(10, 17, 26, 0.75);
    border: 1px solid rgba(53, 182, 236, 0.4);
    text-decoration: none;
    opacity: 0;
    transition: opacity 0.2s ease, background 0.2s ease;
    z-index: 3;
    backdrop-filter: blur(4px);
  }

  .ship-card:hover .img-cta {
    opacity: 1;
  }

  .img-cta:hover {
    background: rgba(53, 182, 236, 0.2);
  }

  /* ── Body ── */
  .ship-body {
    padding: 0.875rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .ship-name {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: #ddeeff;
    margin: 0;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.4;
  }

  /* ── Variants ── */
  .variants {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .variant-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: #0a111a;
    border: 1px solid #1a2e40;
    border-left: 2px solid #1c4d6e;
    text-decoration: none;
    transition: background 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .variant-link:hover {
    background: #0f1e2e;
    border-color: #35b6ec;
    border-left-color: #35b6ec;
    box-shadow: 0 0 8px rgba(53, 182, 236, 0.1);
  }

  /* Loadout CTA — solid border, dimmed at rest */
  .loadout-cta {
    opacity: 0.5;
  }

  .loadout-cta:hover {
    opacity: 1;
  }

  .variant-label {
    font-family: 'Exo 2', sans-serif;
    font-size: 0.8rem;
    color: #c8dae8;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .variant-action {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: #35b6ec;
  }
</style>
