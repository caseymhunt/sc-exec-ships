---
import ShipCard from '../components/ShipCard.astro';
import ships from '../data/ships.json';
import '@fontsource/orbitron/400.css';
import '@fontsource/orbitron/600.css';
import '@fontsource/orbitron/700.css';
import '@fontsource/orbitron/900.css';
import '@fontsource/exo-2/300.css';
import '@fontsource/exo-2/400.css';
import '@fontsource/exo-2/500.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Exec Hangar Ships — Star Citizen Reference</title>
    <meta name="description" content="Complete catalog of Star Citizen Exec Hangar Ships with loadout links." />
  </head>
  <body>
    <div class="bg-grid" aria-hidden="true"></div>

    <header>
      <div class="header-inner">
        <div class="header-label">CLASSIFIED ASSET REGISTRY</div>
        <h1>EXEC HANGAR <span class="accent">SHIPS</span></h1>
        <p class="subtitle">
          Full catalog of obtainable Exec Hangar ships with loadout references via
          <a href="https://www.erkul.games" target="_blank" rel="noopener noreferrer">Erkul.games</a>
        </p>
      </div>
    </header>

    <main>
      <div class="ship-grid">
        {ships.map((ship) => (
          <ShipCard
            name={ship.name}
            manufacturer={ship.manufacturer}
            image={ship.image}
            variants={ship.variants}
          />
        ))}
      </div>
    </main>

    <footer>
      <div class="footer-line"></div>
      <p>Loadout data via <a href="https://www.erkul.games" target="_blank" rel="noopener noreferrer">erkul.games</a> &mdash; Fan resource, not affiliated with Cloud Imperium Games.</p>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg:            #0a0f14;
    --surface:       #0d1520;
    --surface-alt:   #101c2a;
    --border:        #1a2e40;
    --border-bright: #35b6ec;
    --text:          #c8dae8;
    --text-muted:    #5a7a90;
    --accent:        #35b6ec;
    --accent-dim:    #1c4d6e;
    --accent-glow:   rgba(53, 182, 236, 0.18);
  }

  html {
    font-family: 'Exo 2', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
  }

  /* Subtle dot-grid background */
  .bg-grid {
    position: fixed;
    inset: 0;
    z-index: 0;
    background-image:
      radial-gradient(circle, rgba(53, 182, 236, 0.07) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
  }

  body {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    gap: 2.5rem;
  }

  /* ── Header ── */
  header {
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  /* Cyan accent bar at the top */
  header::before {
    content: '';
    position: absolute;
    top: -2.5rem;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent) 0%, transparent 70%);
  }

  .header-label {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    opacity: 0.8;
  }

  header h1 {
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 900;
    color: #ddeeff;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.1;
  }

  header h1 .accent {
    color: var(--accent);
    text-shadow: 0 0 24px rgba(53, 182, 236, 0.5);
  }

  .subtitle {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    font-weight: 300;
  }

  .subtitle a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .subtitle a:hover {
    border-color: var(--accent);
  }

  /* ── Grid ── */
  main { flex: 1; }

  .ship-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  /* ── Footer ── */
  footer {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .footer-line {
    height: 1px;
    background: linear-gradient(90deg, var(--accent) 0%, var(--border) 40%, transparent 100%);
    margin-bottom: 1rem;
    opacity: 0.4;
  }

  footer a {
    color: var(--accent);
    text-decoration: none;
    opacity: 0.8;
  }

  footer a:hover { opacity: 1; }
</style>
